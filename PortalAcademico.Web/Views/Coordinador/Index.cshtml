@model IEnumerable<PortalAcademico.Web.Models.Curso>

@{
    ViewData["Title"] = "Panel de Coordinador - Cursos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Administración de Cursos</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nuevo Curso</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Horario</th>
                        <th>Cupo</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var curso in Model)
                    {
                        <tr>
                            <td class="align-middle"><strong>@curso.Codigo</strong></td>
                            <td class="align-middle">@curso.Nombre</td>
                            <td class="align-middle">@curso.HorarioInicio.ToString(@"hh\:mm") - @curso.HorarioFin.ToString(@"hh\:mm")</td>
                            <td class="align-middle">@curso.CupoMaximo</td>
                            <td class="align-middle">
                                @if (curso.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </td>
                            <td class="align-middle text-end">
                                <a asp-action="Matriculas" asp-route-cursoId="@curso.Id" class="btn btn-sm btn-info text-white me-1" title="Ver Matrículas">
                                    <i class="bi bi-people-fill"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@curso.Id" class="btn btn-sm btn-warning text-white me-1" title="Editar Curso">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                                <form asp-action="ToggleActivo" asp-route-id="@curso.Id" method="post" class="d-inline">
                                    @if (curso.Activo)
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Desactivar">
                                            <i class="bi bi-dash-circle"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Activar">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
