@model PortalAcademico.Web.Models.ViewModels.CursoFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<input type="hidden" asp-for="Id" />

<div class="mb-3">
    <label asp-for="Codigo" class="form-label fw-bold"></label>
    <input asp-for="Codigo" class="form-control" />
    <span asp-validation-for="Codigo" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Nombre" class="form-label fw-bold"></label>
    <input asp-for="Nombre" class="form-control" />
    <span asp-validation-for="Nombre" class="text-danger"></span>
</div>

<div class="row mb-3">
    <div class="col-md-6">
        <label asp-for="Creditos" class="form-label fw-bold"></label>
        <input asp-for="Creditos" class="form-control" type="number" />
        <span asp-validation-for="Creditos" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="CupoMaximo" class="form-label fw-bold"></label>
        <input asp-for="CupoMaximo" class="form-control" type="number" />
        <span asp-validation-for="CupoMaximo" class="text-danger"></span>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-6">
        <label asp-for="HorarioInicio" class="form-label fw-bold"></label>
        <input asp-for="HorarioInicio" class="form-control" type="time" />
        <span asp-validation-for="HorarioInicio" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="HorarioFin" class="form-label fw-bold"></label>
        <input asp-for="HorarioFin" class="form-control" type="time" />
        <span asp-validation-for="HorarioFin" class="text-danger"></span>
    </div>
</div>

<div class="form-check form-switch mb-3 mt-4">
    <input class="form-check-input" type="checkbox" asp-for="Activo">
    <label class="form-check-label fw-bold" asp-for="Activo">Curso Activo</label>
</div>
